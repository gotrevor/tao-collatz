#!/usr/bin/env bash
# TaoCollatz green-gate: a commit that touches Lean/build files must `lake build` clean.
#
# Build-only by design. A repo-local core.hooksPath REPLACES the global hook (it is
# single-valued), so this intentionally drops the global protected-branch guard — `main`
# is this repo's working branch and direct commits are expected.
#
# Enable on a fresh clone (core.hooksPath is local config, NOT tracked):
#     git config core.hooksPath .githooks
set -euo pipefail

# --no-renames so a rename emits its two literal paths (old + new) and is not skipped.
changed=$(git diff --cached --name-only --no-renames)

# Blueprint/governance sources are coordinator-owned.  This is intentionally a
# commit-time hard stop rather than a prompt rule: unattended proof workers have
# historically mixed proof edits with reviewer-facing status changes.  A human
# coordinator making a deliberate governance commit sets the documented override.
if [ "${TAO_ALLOW_GOVERNANCE_EDIT:-0}" != "1" ]; then
  protected=$(printf '%s\n' "$changed" | grep -E \
    '^(BLUEPRINT\.md|SKELETON-SPEC\.md|blueprint/|judge/|DIRECTION\.md|EXECUTABILITY\.md|STATUS\.md|tools/tao_stmt_diff\.py$)' \
    || true)
  if [ -n "$protected" ]; then
    echo "❌ protected coordinator-owned paths are staged:" >&2
    printf '   %s\n' $protected >&2
    echo "Proof workers must leave blueprint/governance files untouched." >&2
    echo "Coordinator override: TAO_ALLOW_GOVERNANCE_EDIT=1 git commit ..." >&2
    exit 1
  fi
fi

if printf '%s\n' "$changed" | grep -qE '\.lean$|lakefile\.(toml|lean)$|lake-manifest\.json$|^lean-toolchain$'; then
  echo "tao-collatz pre-commit: lake build…"
  if ! lake build; then
    echo "❌ lake build failed — commit aborted (fix or use 'git commit --no-verify' to override)." >&2
    exit 1
  fi
  echo "✅ build green."
fi
